# Backend FastAPI base URL used by the /admin panel.
# Local dev defaults to http://localhost:8000 when unset; set this to the
# deployed backend origin for production builds.
VITE_API_BASE_URL=http://localhost:8000

# Mapbox public token for the /admin location search (Search Box API).
# Use the same value as the app's MAPBOX_ACCESS_TOKEN. Without it, the picker
# falls back to manual lat/lng entry.
VITE_MAPBOX_TOKEN=

# PostHog (optional) — enables admin-usage analytics + the dashboard link.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Note: the public Firebase web config is committed in src/firebase.ts (it is
# safe to ship; access is governed by Firestore rules + backend ADMIN_UIDS).
