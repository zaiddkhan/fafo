<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) launch theme. The OS draws its own splash here
         using these attributes, ignoring the legacy launch_background bitmap.
         We point the animated icon at a transparent drawable so only the
         brand-blue background shows — no Flutter logo. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
    </style>
</resources>
