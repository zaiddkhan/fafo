FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
ADMIN_UIDS=
CORS_ORIGINS=
FRIEND_INVITE_BASE_URL=https://getfafo.app/invite

# Admin web console (/console) — email + password protected.
ADMIN_EMAIL=you@getfafo.app
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SESSION_SECRET=generate-with-openssl-rand-hex-32
# Set to true when the console is served over HTTPS (production).
ADMIN_COOKIE_SECURE=false

# --- Push notifications ---
# Shared secret guarding /internal/cron/* (sent by Cloud Scheduler as X-Cron-Secret).
# Leave blank to keep the cron endpoints disabled (they 503 until set).
CRON_SHARED_SECRET=generate-with-openssl-rand-hex-32
# Per-user daily push ceiling (urgent real-time types bypass it).
NOTIFICATION_GLOBAL_DAILY_CAP=10
# Quiet hours in the user's local time; non-urgent pushes are deferred to QUIET_HOURS_END.
QUIET_HOURS_START=23
QUIET_HOURS_END=8
# Outbox retry behaviour.
DISPATCH_MAX_ATTEMPTS=5
DISPATCH_BATCH_SIZE=200
