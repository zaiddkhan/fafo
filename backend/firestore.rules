rules_version = '2';

// Fafo Firestore security rules.
//
// The backend (FastAPI) uses the Firebase Admin SDK, which bypasses these rules
// entirely — so ALL writes and almost all reads happen server-side and stay
// locked down here. The Flutter client only talks to Firestore directly for one
// thing: the live event stream that powers real-time map updates. That is the
// only client-side allowance below; everything else is denied by default.
service cloud.firestore {
  match /databases/{database}/documents {

    // Events are public (PRD), so any signed-in user may read them live from the
    // client for the real-time map. All writes go through the verified-creator
    // backend endpoints only.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;

      // Joinee lists are managed server-side; never exposed to the client directly.
      match /{subcollection=**} {
        allow read, write: if false;
      }
    }

    // Public marketing-site waitlist. The getfafo.app landing page writes here
    // directly with the Firebase web SDK from unauthenticated visitors, so this
    // is create-only and never readable from the client. Emails are read back
    // server-side (Admin SDK) only.
    match /waitlist/{entryId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'source', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 3
                    && request.resource.data.email.size() < 320
                    && request.resource.data.source is string;
      allow read, update, delete: if false;
    }

    // Everything else is server-only. The client reaches these through the
    // authenticated REST API, never directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
